}

class Cylinder extends Shape {
    constructor(s, segments = 24) {
        super();
        const r = s / 2;
        const h = s;
        const topY = h / 2;
        const bottomY = -h / 2;
        for (let i = 0; i < segments; i++) {
            const a = (2 * Math.PI * i) / segments;
            this.vertices.push(new Point3D(r * Math.cos(a), topY, r * Math.sin(a)));
        }
        for (let i = 0; i < segments; i++) {
            const a = (2 * Math.PI * i) / segments;
            this.vertices.push(new Point3D(r * Math.cos(a), bottomY, r * Math.sin(a)));
        }
        for (let i = 0; i < segments; i++) {
            const next = (i + 1) % segments;
            this.edges.push(new Edge(this.vertices[i], this.vertices[next], this.edges.length, i, next));
        }
        for (let i = 0; i < segments; i++) {
            const a = segments + i;
            const b = segments + ((i + 1) % segments);
            this.edges.push(new Edge(this.vertices[a], this.vertices[b], this.edges.length, a, b));
        }
        for (let i = 0; i < segments; i++) {
            this.edges.push(new Edge(this.vertices[i], this.vertices[segments + i], this.edges.length, i, segments + i));
        }
        this.faces.push([...Array(segments).keys()]);
        this.faces.push([...Array(segments).keys()].map(i => segments + (segments - 1 - i)));
        for (let i = 0; i < segments; i++) {
            const next = (i + 1) % segments;
            this.faces.push([i, next, segments + next, segments + i]);
        }
        this.buildConnectivity();
    }
}

class Cone extends Shape {
    constructor(s, segments = 24) {
        super();
        const r = s / 2;
        const h = s;
        const baseY = -h / 2;
        const apexY = h / 2;
        for (let i = 0; i < segments; i++) {
            const a = (2 * Math.PI * i) / segments;
            this.vertices.push(new Point3D(r * Math.cos(a), baseY, r * Math.sin(a)));
        }
        const apexIndex = this.vertices.length;
        this.vertices.push(new Point3D(0, apexY, 0));
        for (let i = 0; i < segments; i++) {
