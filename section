        }
        for (let i = 0; i < segments; i++) {
            this.edges.push(new Edge(this.vertices[i], this.vertices[apexIndex], this.edges.length, i, apexIndex));
        }
        this.faces.push([...Array(segments).keys()]);
        for (let i = 0; i < segments; i++) {
