<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>🔷 3D Сечения Геометрических Фигур</title>
    <style>
        :root {
            --bg-primary: #0f172a;
            --bg-secondary: #1e293b;
            --bg-card: rgba(30, 41, 59, 0.8);
            --accent: #3b82f6;
            --accent-glow: rgba(59, 130, 246, 0.4);
            --success: #10b981;
            --warning: #f59e0b;
            --error: #ef4444;
            --text-primary: #f1f5f9;
            --text-secondary: #94a3b8;
            --border: rgba(255, 255, 255, 0.1);
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            overflow: hidden;
        }
        .container {
            max-width: 1540px;
            margin: 0 auto;
            padding: 1rem;
            height: 100vh;
            display: flex;
            flex-direction: column;
        }
        header {
            text-align: center;
            margin-bottom: 1rem;
            flex-shrink: 0;
        }
        h1 {
            font-size: 2rem;
            background: linear-gradient(135deg, #60a5fa, #a78bfa);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.25rem;
        }
        .subtitle {
            color: var(--text-secondary);
            font-size: 0.9rem;
        }
        .main-grid {
            display: grid;
            grid-template-columns: 340px 1fr 380px;
            gap: 1rem;
            flex-grow: 1;
            min-height: 0;
        }
        @media (max-width: 1280px) {
            .main-grid { grid-template-columns: 1fr; overflow-y: auto; }
            body { overflow: auto; }
        }
        .panel {
            background: var(--bg-card);
            backdrop-filter: blur(12px);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 1.25rem;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
            display: flex;
            flex-direction: column;
            overflow-y: auto;
        }
        .panel-title {
            font-size: 1.05rem;
            font-weight: 600;
            margin-bottom: 0.9rem;
            color: var(--accent);
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex-shrink: 0;
        }
        .shape-selector,
        .mode-selector {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 0.5rem;
            margin-bottom: 1rem;
        }
        .shape-btn,
        .mode-btn,
        .section-tab-btn {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            color: var(--text-primary);
            padding: 0.6rem;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.84rem;
            text-align: center;
        }
        .shape-btn:hover,
        .mode-btn:hover,
        .section-tab-btn:hover {
            background: var(--accent);
        }
        .shape-btn.active,
        .mode-btn.active,
        .section-tab-btn.active {
            background: var(--accent);
            border-color: var(--accent);
            box-shadow: 0 0 10px var(--accent-glow);
        }
        .control-group { margin-bottom: 1rem; }
        label {
            display: block;
            margin-bottom: 0.4rem;
            color: var(--text-secondary);
            font-size: 0.85rem;
        }
        input[type="range"] {
            width: 100%;
            height: 4px;
            background: var(--bg-secondary);
            border-radius: 2px;
            appearance: none;
            cursor: pointer;
        }
        input[type="range"]::-webkit-slider-thumb {
            appearance: none;
            width: 16px;
            height: 16px;
            background: var(--accent);
            border-radius: 50%;
            cursor: pointer;
        }
        select,
        input[type="number"] {
            width: 100%;
            background: var(--bg-secondary);
            color: var(--text-primary);
            border: 1px solid var(--border);
            border-radius: 6px;
            padding: 0.55rem;
            font-size: 0.84rem;
        }
        .equation-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 0.5rem;
            margin-bottom: 0.75rem;
        }
        .equation-help {
            color: var(--text-secondary);
            font-size: 0.78rem;
            margin-top: -0.3rem;
            margin-bottom: 1rem;
        }
        .canvas-container {
            background: var(--bg-secondary);
            border-radius: 12px;
            overflow: hidden;
            position: relative;
            flex-grow: 1;
            min-height: 460px;
            box-shadow: inset 0 0 20px rgba(0,0,0,0.5);
        }
        #mainCanvas {
            width: 100%;
            height: 100%;
            display: block;
            cursor: crosshair;
            touch-action: none;
        }
        .toolbar {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
            margin-top: 1rem;
            flex-shrink: 0;
        }
        .tool-btn {
            background: var(--bg-secondary);
            border: 1px solid var(--border);
            color: var(--text-primary);
            padding: 0.55rem 0.8rem;
            border-radius: 6px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 0.8rem;
            flex: 1;
            text-align: center;
        }
        .tool-btn:hover { background: var(--accent); }
        .tool-btn.active {
            background: var(--accent);
            border-color: var(--accent);
            box-shadow: 0 0 10px var(--accent-glow);
        }
        .tool-btn.danger {
            background: rgba(239, 68, 68, 0.2);
            border-color: var(--error);
            color: var(--error);
        }
        .tool-btn.danger:hover {
            background: var(--error);
            color: white;
        }
        .instruction {
            background: rgba(245, 158, 11, 0.1);
            border: 1px solid var(--warning);
            border-radius: 6px;
            padding: 0.8rem;
            margin-bottom: 1rem;
            font-size: 0.84rem;
            color: #fcd34d;
            flex-shrink: 0;
        }
        .sections-list,
        .points-list {
            background: rgba(15, 23, 42, 0.18);
            border-radius: 8px;
            padding: 0.4rem;
            margin-bottom: 1rem;
            overflow-y: auto;
        }
        .sections-list {
            min-height: 100px;
            max-height: 190px;
        }
        .points-list {
            min-height: 120px;
            max-height: 260px;
        }
        .section-item {
            background: var(--bg-secondary);
            padding: 0.55rem;
            border-radius: 6px;
            margin-bottom: 0.45rem;
            border-left: 4px solid transparent;
            display: grid;
            grid-template-columns: 1fr auto;
            gap: 0.5rem;
            align-items: center;
        }
        .section-item.active {
            outline: 1px solid var(--accent);
        }
        .section-meta {
            font-size: 0.82rem;
            color: var(--text-secondary);
        }
        .section-badge {
            width: 14px;
            height: 14px;
            border-radius: 50%;
            border: 2px solid rgba(255,255,255,0.7);
            display: inline-block;
            margin-right: 0.4rem;
            vertical-align: middle;
        }
        .point-item {
            background: var(--bg-secondary);
            padding: 0.6rem;
            border-radius: 6px;
            margin-bottom: 0.4rem;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 3px solid var(--accent);
            font-size: 0.88rem;
        }
        .remove-btn {
            background: var(--error);
            border: none;
            color: white;
            width: 20px;
            height: 20px;
            border-radius: 50%;
            cursor: pointer;
            font-size: 0.7rem;
            flex-shrink: 0;
        }
        .stats {
            display: grid;
            grid-template-columns: repeat(3, 1fr);
            gap: 0.5rem;
            margin-top: auto;
            flex-shrink: 0;
        }
        .stat-item {
            background: var(--bg-secondary);
            padding: 0.55rem;
            border-radius: 6px;
            text-align: center;
        }
        .stat-value {
            font-size: 1.1rem;
            font-weight: bold;
            color: var(--accent);
        }
        .stat-label {
            font-size: 0.72rem;
            color: var(--text-secondary);
        }
        @keyframes popIn {
            0% { transform: scale(0); opacity: 0; }
            70% { transform: scale(1.2); opacity: 1; }
            100% { transform: scale(1); opacity: 0; }
        }
        .click-feedback {
            position: absolute;
            color: var(--success);
            font-weight: bold;
            font-size: 14px;
            pointer-events: none;
            animation: popIn 0.8s ease-out forwards;
            text-shadow: 0 2px 4px rgba(0,0,0,0.8);
            z-index: 10;
        }
    </style>
</head>
<body>
<div class="container">
    <header>
        <h1>🔷 3D Сечения</h1>
        <p class="subtitle">Конструктор нескольких сечений многогранников и тел вращения</p>
    </header>
    <div class="main-grid">
        <div class="panel">
            <h2 class="panel-title">📐 Фигура</h2>
            <div class="shape-selector">
                <button class="shape-btn active" data-shape="cube">Куб</button>
                <button class="shape-btn" data-shape="pyramid">Пирамида</button>
                <button class="shape-btn" data-shape="hexagonalPyramid">6-уг. пирамида</button>
                <button class="shape-btn" data-shape="prism">Призма</button>
                <button class="shape-btn" data-shape="tetrahedron">Тетраэдр</button>
                <button class="shape-btn" data-shape="cylinder">Цилиндр</button>
                <button class="shape-btn" data-shape="cone">Конус</button>
                <button class="shape-btn" data-shape="sphere">Шар</button>
            </div>

            <h2 class="panel-title">📍 Режим точки</h2>
            <div class="mode-selector">
                <button class="mode-btn active" data-mode="edge">По рёбрам</button>
                <button class="mode-btn" data-mode="face">По граням</button>
            </div>

            <h2 class="panel-title">⚙️ Параметры</h2>
            <div class="control-group">
                <label>Размер: <span id="sizeValue">200</span></label>
                <input type="range" id="sizeSlider" min="100" max="300" value="200">
            </div>
            <div class="control-group">
                <label>Поворот X: <span id="rotXValue">-30</span>°</label>
                <input type="range" id="rotXSlider" min="-180" max="180" value="-30">
            </div>
            <div class="control-group">
                <label>Поворот Y: <span id="rotYValue">45</span>°</label>
                <input type="range" id="rotYSlider" min="-180" max="180" value="45">
            </div>
            <div class="control-group">
                <label>Толщина линий фигуры: <span id="edgeThicknessValue">2</span></label>
                <input type="range" id="edgeThicknessSlider" min="1" max="6" step="0.5" value="2">
            </div>

            <h2 class="panel-title">🧮 Построение по уравнению</h2>
            <div class="equation-grid">
                <input type="number" id="planeA" value="1" step="1" placeholder="A">
                <input type="number" id="planeB" value="1" step="1" placeholder="B">
                <input type="number" id="planeC" value="1" step="1" placeholder="C">
                <input type="number" id="planeD" value="0" step="1" placeholder="D">
            </div>
            <div class="equation-help">Уравнение задаётся в виде Ax + By + Cz + D = 0, где A, B, C, D — целые числа.</div>

            <div class="toolbar" style="margin-top:0; margin-bottom:1rem;">
                <button class="tool-btn" id="buildEquationBtn">🧮 Построить по уравнению</button>
                <button class="tool-btn danger" id="clearCurrentBtn">🧹 Очистить текущее</button>
            </div>

            <div class="toolbar">
                <button class="tool-btn" id="newSectionBtn">➕ Новое сечение</button>
                <button class="tool-btn" id="buildSectionBtn">✂️ Построить текущее</button>
                <button class="tool-btn danger" id="deleteSectionBtn">🗑️ Удалить текущее</button>
            </div>

            <div class="stats">
                <div class="stat-item">
                    <div class="stat-value" id="sectionsCount">1</div>
                    <div class="stat-label">Сечений</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="activePointsCount">0</div>
                    <div class="stat-label">Точек в текущем</div>
                </div>
                <div class="stat-item">
                    <div class="stat-value" id="builtCount">0</div>
                    <div class="stat-label">Построено</div>
                </div>
            </div>
        </div>

        <div class="panel" style="padding: 0; background: transparent; border: none; box-shadow: none;">
            <div class="canvas-container">
                <canvas id="mainCanvas"></canvas>
            </div>

            <div class="toolbar" style="background: var(--bg-card); padding: 1rem; border-radius: 12px; margin-top: 1rem; border: 1px solid var(--border);">
                <button class="tool-btn" id="resetViewBtn">🔄 Вид спереди</button>
                <button class="tool-btn" id="autoRotateBtn">🌀 Автовращение</button>
                <button class="tool-btn" id="resetZoomBtn">🔍 Сброс зума</button>
                <button class="tool-btn" id="toggleWireframeBtn">👁️ Сплошной/Каркас</button>
                <button class="tool-btn" id="toggleWarmLightBtn">☀️ Тёплая подсветка</button>
                <button class="tool-btn" id="toggleLabelsBtn">🔤 Подписи вершин/точек</button>
                <button class="tool-btn" id="toggleConstructionStepsBtn">👣 Пошаговое построение</button>
                <button class="tool-btn" id="toggleTraceMethodBtn">🧭 Метод следов</button>
                <button class="tool-btn" id="toggleAuxiliaryPlaneBtn">🪟 Вспомогательная плоскость</button>
            </div>

            <div style="background: var(--bg-card); padding: 1rem; border-radius: 12px; margin-top: 1rem; border: 1px solid var(--border);">
                <div class="control-group" style="margin-bottom:0;">
                    <label>Скорость вращения: <span id="autoRotateSpeedValue">0.6</span></label>
                    <input type="range" id="autoRotateSpeedSlider" min="0.1" max="5" step="0.1" value="0.6">
                </div>
            </div>
        </div>

        <div class="panel">
            <h2 class="panel-title">🧩 Сечения</h2>
            <div class="sections-list" id="sectionsList"></div>

            <div id="sectionInfo" style="display: none; background: rgba(59, 130, 246, 0.1); border: 1px solid var(--accent); border-radius: 8px; padding: 1rem; margin-bottom: 1rem;">
                <strong style="color: var(--accent);">Текущее сечение</strong>
                <p id="sectionDetails" style="font-size: 0.85rem; margin-top: 0.5rem; color: var(--text-secondary);"></p>
            </div>

            <div class="instruction">
                💡 <strong>Как работать:</strong><br>
                1. Создайте новое сечение.<br>
                2. Либо поставьте точки по рёбрам/граням, либо задайте уравнение плоскости.<br>
                3. Постройте текущее сечение.<br>
                4. Можно включить пошаговый показ, метод следов или вспомогательную плоскость.<br>
                5. Метод следов и вспомогательная плоскость полноценно работают для многогранников.
            </div>

            <h2 class="panel-title">📍 Точки текущего сечения</h2>
            <div class="points-list" id="pointsList">
                <p style="color: var(--text-secondary); text-align: center; padding: 1rem; font-size: 0.9rem;">Нет точек</p>
            </div>

            <h2 class="panel-title">🎨 Стиль текущего</h2>
            <div class="control-group">
                <label>Прозрачность: <span id="opacityValue">0.6</span></label>
                <input type="range" id="opacitySlider" min="0.1" max="1" step="0.1" value="0.6">
            </div>
            <div class="control-group">
                <label>Цвет текущего сечения:</label>
                <input type="color" id="sectionColor" value="#3b82f6" style="width: 100%; height: 35px; border: none; background: none;">
            </div>
        </div>
    </div>
</div>

<script>
class Point3D {
    constructor(x, y, z) {
        this.x = x; this.y = y; this.z = z;
    }
    clone() { return new Point3D(this.x, this.y, this.z); }
    add(p) { return new Point3D(this.x + p.x, this.y + p.y, this.z + p.z); }
    sub(p) { return new Point3D(this.x - p.x, this.y - p.y, this.z - p.z); }
    scale(k) { return new Point3D(this.x * k, this.y * k, this.z * k); }
    dot(p) { return this.x * p.x + this.y * p.y + this.z * p.z; }
    cross(p) {
        return new Point3D(
            this.y * p.z - this.z * p.y,
            this.z * p.x - this.x * p.z,
            this.x * p.y - this.y * p.x
        );
    }
    length() { return Math.sqrt(this.x * this.x + this.y * this.y + this.z * this.z); }
    normalize() {
        const len = this.length();
        if (len < 1e-9) return new Point3D(0, 0, 0);
        return this.scale(1 / len);
    }
    distanceTo(p) { return this.sub(p).length(); }
    rotateX(angle) {
        const rad = angle * Math.PI / 180;
        const c = Math.cos(rad), s = Math.sin(rad);
        return new Point3D(this.x, this.y * c - this.z * s, this.y * s + this.z * c);
    }
    rotateY(angle) {
        const rad = angle * Math.PI / 180;
        const c = Math.cos(rad), s = Math.sin(rad);
        return new Point3D(this.x * c + this.z * s, this.y, -this.x * s + this.z * c);
    }
    rotate(rx, ry) { return this.rotateX(rx).rotateY(ry); }
    project(w, h, cameraDistance = 500, zoom = 1) {
        const z = this.z + cameraDistance;
        const safeZ = Math.max(z, 1);
        const f = (cameraDistance * zoom) / safeZ;
        return { x: w / 2 + this.x * f, y: h / 2 - this.y * f, z: this.z, f };
    }
}

class Edge {
    constructor(v1, v2, idx, v1Index, v2Index) {
        this.v1 = v1;
        this.v2 = v2;
        this.idx = idx;
        this.v1Index = v1Index;
        this.v2Index = v2Index;
        this.faceIndices = [];
    }
    isHovered(x, y, projV1, projV2, threshold = 10) {
        const A = x - projV1.x;
        const B = y - projV1.y;
        const C = projV2.x - projV1.x;
        const D = projV2.y - projV1.y;
        const dot = A * C + B * D;
        const lenSq = C * C + D * D;
        let param = -1;
        if (lenSq !== 0) param = dot / lenSq;
        let xx, yy;
        if (param < 0) { xx = projV1.x; yy = projV1.y; }
        else if (param > 1) { xx = projV2.x; yy = projV2.y; }
        else { xx = projV1.x + param * C; yy = projV1.y + param * D; }
        const dx = x - xx;
        const dy = y - yy;
        return Math.sqrt(dx * dx + dy * dy) < threshold;
    }
    projectParamFromScreen(x, y, projV1, projV2) {
        const A = x - projV1.x;
        const B = y - projV1.y;
        const C = projV2.x - projV1.x;
        const D = projV2.y - projV1.y;
        const lenSq = C * C + D * D;
        if (lenSq < 1e-9) return 0;
        return (A * C + B * D) / lenSq;
    }
    getPointAt(param) {
        const p = new Point3D(
            this.v1.x + (this.v2.x - this.v1.x) * param,
            this.v1.y + (this.v2.y - this.v1.y) * param,
            this.v1.z + (this.v2.z - this.v1.z) * param
        );
        p.hostType = 'edge';
        p.edgeIdx = this.idx;
        p.param = param;
        return p;
    }
}

class Shape {
    constructor() {
        this.vertices = [];
        this.edges = [];
        this.faces = [];
    }
    buildConnectivity() {
        this.edges.forEach(e => e.faceIndices = []);
        this.faces.forEach((face, fIdx) => {
            for (let i = 0; i < face.length; i++) {
                const a = face[i];
                const b = face[(i + 1) % face.length];
                const edgeIdx = this.edges.findIndex(e =>
                    (e.v1Index === a && e.v2Index === b) ||
                    (e.v1Index === b && e.v2Index === a)
                );
                if (edgeIdx !== -1) this.edges[edgeIdx].faceIndices.push(fIdx);
            }
        });
    }
    rotate(rx, ry) {
        return this.vertices.map(v => v.rotate(rx, ry));
    }
}

class Cube extends Shape {
    constructor(s) {
        super();
        const h = s / 2;
        this.vertices = [
            new Point3D(-h,-h,-h), new Point3D(h,-h,-h), new Point3D(h,h,-h), new Point3D(-h,h,-h),
            new Point3D(-h,-h,h),  new Point3D(h,-h,h),  new Point3D(h,h,h),  new Point3D(-h,h,h)
        ];
        const idx = [[0,1],[1,2],[2,3],[3,0],[4,5],[5,6],[6,7],[7,4],[0,4],[1,5],[2,6],[3,7]];
        this.edges = idx.map((pair, i) => new Edge(this.vertices[pair[0]], this.vertices[pair[1]], i, pair[0], pair[1]));
        this.faces = [[0,1,2,3],[4,5,6,7],[0,1,5,4],[2,3,7,6],[0,3,7,4],[1,2,6,5]];
        this.buildConnectivity();
    }
}

class Pyramid extends Shape {
    constructor(s) {
        super();
        const h = s / 2, H = s;
        this.vertices = [
            new Point3D(-h,-h,-h), new Point3D(h,-h,-h), new Point3D(h,-h,h), new Point3D(-h,-h,h),
            new Point3D(0,H,0)
        ];
        const idx = [[0,1],[1,2],[2,3],[3,0],[0,4],[1,4],[2,4],[3,4]];
        this.edges = idx.map((pair, i) => new Edge(this.vertices[pair[0]], this.vertices[pair[1]], i, pair[0], pair[1]));
        this.faces = [[0,1,2,3],[0,1,4],[1,2,4],[2,3,4],[3,0,4]];
        this.buildConnectivity();
    }
}

class HexagonalPyramid extends Shape {
    constructor(s) {
        super();
        const r = s / 2;
        const baseY = -s / 2;
        const apexY = s / 2;
        for (let i = 0; i < 6; i++) {
            const a = (2 * Math.PI * i) / 6;
            this.vertices.push(new Point3D(r * Math.cos(a), baseY, r * Math.sin(a)));
        }
        const apexIndex = this.vertices.length;
        this.vertices.push(new Point3D(0, apexY, 0));
        for (let i = 0; i < 6; i++) {
            const next = (i + 1) % 6;
            this.edges.push(new Edge(this.vertices[i], this.vertices[next], this.edges.length, i, next));
        }
        for (let i = 0; i < 6; i++) {
            this.edges.push(new Edge(this.vertices[i], this.vertices[apexIndex], this.edges.length, i, apexIndex));
        }
        this.faces.push([0,1,2,3,4,5]);
        for (let i = 0; i < 6; i++) {
            const next = (i + 1) % 6;
            this.faces.push([i, next, apexIndex]);
        }
        this.buildConnectivity();
    }
}

class Prism extends Shape {
    constructor(s) {
        super();
        const h = s / 2, H = s * 0.8;
        this.vertices = [
            new Point3D(-h,-H/2,-h), new Point3D(h,-H/2,-h), new Point3D(0,-H/2,h),
            new Point3D(-h,H/2,-h),  new Point3D(h,H/2,-h),  new Point3D(0,H/2,h)
        ];
        const idx = [[0,1],[1,2],[2,0],[3,4],[4,5],[5,3],[0,3],[1,4],[2,5]];
        this.edges = idx.map((pair, i) => new Edge(this.vertices[pair[0]], this.vertices[pair[1]], i, pair[0], pair[1]));
        this.faces = [[0,1,2],[3,4,5],[0,1,4,3],[1,2,5,4],[2,0,3,5]];
        this.buildConnectivity();
    }
}

class Tetrahedron extends Shape {
