}

class Sphere extends Shape {
    constructor(s, latSegments = 10, lonSegments = 16) {
        super();
        const r = s / 2;
        const topIndex = this.vertices.length;
        this.vertices.push(new Point3D(0, r, 0));
        const ringIndices = [];
        for (let lat = 1; lat < latSegments; lat++) {
            const phi = Math.PI * lat / latSegments;
            const y = r * Math.cos(phi);
            const rr = r * Math.sin(phi);
            const ring = [];
            for (let lon = 0; lon < lonSegments; lon++) {
                const theta = 2 * Math.PI * lon / lonSegments;
                const x = rr * Math.cos(theta);
                const z = rr * Math.sin(theta);
                ring.push(this.vertices.length);
                this.vertices.push(new Point3D(x, y, z));
            }
            ringIndices.push(ring);
        }
        const bottomIndex = this.vertices.length;
        this.vertices.push(new Point3D(0, -r, 0));
        for (const ring of ringIndices) {
            for (let i = 0; i < lonSegments; i++) {
                const a = ring[i];
                const b = ring[(i + 1) % lonSegments];
                this.edges.push(new Edge(this.vertices[a], this.vertices[b], this.edges.length, a, b));
            }
        }
        for (let k = 0; k < ringIndices.length - 1; k++) {
            const ringA = ringIndices[k];
            const ringB = ringIndices[k + 1];
            for (let i = 0; i < lonSegments; i++) {
                this.edges.push(new Edge(this.vertices[ringA[i]], this.vertices[ringB[i]], this.edges.length, ringA[i], ringB[i]));
            }
        }
        if (ringIndices.length > 0) {
            for (let i = 0; i < lonSegments; i++) {
                this.edges.push(new Edge(this.vertices[topIndex], this.vertices[ringIndices[0][i]], this.edges.length, topIndex, ringIndices[0][i]));
            }
            const lastRing = ringIndices[ringIndices.length - 1];
            for (let i = 0; i < lonSegments; i++) {
                this.edges.push(new Edge(this.vertices[lastRing[i]], this.vertices[bottomIndex], this.edges.length, lastRing[i], bottomIndex));
            }
        }
        if (ringIndices.length > 0) {
            const firstRing = ringIndices[0];
            for (let i = 0; i < lonSegments; i++) {
                const next = (i + 1) % lonSegments;
                this.faces.push([topIndex, firstRing[next], firstRing[i]]);
            }
            for (let k = 0; k < ringIndices.length - 1; k++) {
                const ringA = ringIndices[k];
                const ringB = ringIndices[k + 1];
                for (let i = 0; i < lonSegments; i++) {
                    const next = (i + 1) % lonSegments;
                    this.faces.push([ringA[i], ringA[next], ringB[next], ringB[i]]);
                }
            }
            const lastRing = ringIndices[ringIndices.length - 1];
            for (let i = 0; i < lonSegments; i++) {
                const next = (i + 1) % lonSegments;
                this.faces.push([lastRing[i], lastRing[next], bottomIndex]);
            }
        }
        this.buildConnectivity();
    }
}

function planeFrom3Points(a, b, c) {
    const ab = b.sub(a);
    const ac = c.sub(a);
    const normal = ab.cross(ac);
    const len = normal.length();
    if (len < 1e-6) return null;
    const n = normal.scale(1 / len);
    const d = -n.dot(a);
    return { n, d };
}

function signedDistanceToPlane(plane, p) {
    return plane.n.dot(p) + plane.d;
}

function intersectSegmentPlane(a, b, plane, eps = 1e-7) {
    const da = signedDistanceToPlane(plane, a);
    const db = signedDistanceToPlane(plane, b);
    if (Math.abs(da) < eps && Math.abs(db) < eps) return [a.clone(), b.clone()];
    if (Math.abs(da) < eps) return [a.clone()];
    if (Math.abs(db) < eps) return [b.clone()];
    if (da * db > 0) return [];
    const t = da / (da - db);
    if (t < -eps || t > 1 + eps) return [];
    return [new Point3D(
        a.x + (b.x - a.x) * t,
        a.y + (b.y - a.y) * t,
        a.z + (b.z - a.z) * t
    )];
}

function samePoint(a, b, eps = 1e-4) {
    return a.distanceTo(b) < eps;
}

function uniquePoints(points, eps = 1e-4) {
    const result = [];
    for (const p of points) {
        if (!result.some(q => samePoint(p, q, eps))) result.push(p);
    }
    return result;
}

function buildSectionPolygon(shape, plane) {
    const raw = [];
    for (const edge of shape.edges) {
        const pts = intersectSegmentPlane(edge.v1, edge.v2, plane);
        raw.push(...pts);
    }
    const points = uniquePoints(raw);
    if (points.length < 3) return [];
    let center = new Point3D(0, 0, 0);
    for (const p of points) center = center.add(p);
    center = center.scale(1 / points.length);
    const n = plane.n.normalize();
    const helper = Math.abs(n.x) < 0.9 ? new Point3D(1, 0, 0) : new Point3D(0, 1, 0);
    const u = n.cross(helper).normalize();
    const v = n.cross(u).normalize();
    const withAngles = points.map(p => {
        const d = p.sub(center);
        const x = d.dot(u);
        const y = d.dot(v);
        return { p, angle: Math.atan2(y, x) };
    });
    withAngles.sort((a, b) => a.angle - b.angle);
    return withAngles.map(item => item.p);
}

function polygonArea3D(points) {
    if (!points || points.length < 3) return 0;
    const p0 = points[0];
    let area = 0;
    for (let i = 1; i < points.length - 1; i++) {
        const a = points[i].sub(p0);
        const b = points[i + 1].sub(p0);
        area += a.cross(b).length() / 2;
    }
    return area;
}

function gcd2(a, b) {
    a = Math.abs(a);
    b = Math.abs(b);
    while (b !== 0) {
        const t = a % b;
        a = b;
        b = t;
    }
    return a;
}

function gcdArray(arr) {
    const nums = arr.map(v => Math.abs(Math.round(v))).filter(v => v !== 0);
    if (nums.length === 0) return 1;
    return nums.reduce((acc, v) => gcd2(acc, v), nums[0]);
}

function lcm2(a, b) {
    if (a === 0 || b === 0) return 0;
    return Math.abs(a * b) / gcd2(a, b);
}

function approximateFraction(x, maxDen = 1000) {
    if (!isFinite(x)) return { num: 0, den: 1 };
    if (Math.abs(x) < 1e-12) return { num: 0, den: 1 };
    let bestNum = Math.round(x);
    let bestDen = 1;
    let bestErr = Math.abs(x - bestNum);
    for (let den = 1; den <= maxDen; den++) {
        const num = Math.round(x * den);
        const err = Math.abs(x - num / den);
        if (err < bestErr) {
            bestErr = err;
            bestNum = num;
            bestDen = den;
            if (err < 1e-10) break;
        }
    }
    const g = gcd2(bestNum, bestDen);
    return { num: bestNum / g, den: bestDen / g };
}

function planeToIntegerCoefficients(plane) {
    const fracs = [plane.n.x, plane.n.y, plane.n.z, plane.d].map(v => approximateFraction(v, 1000));
    let lcm = 1;
    for (const f of fracs) lcm = lcm2(lcm, f.den);
    let coeffs = fracs.map(f => f.num * (lcm / f.den));
    coeffs = coeffs.map(v => Math.round(v));
    const g = gcdArray(coeffs);
    coeffs = coeffs.map(v => v / g);
    const firstNonZero = coeffs.find(v => v !== 0) || 1;
    if (firstNonZero < 0) coeffs = coeffs.map(v => -v);
    return { A: coeffs[0], B: coeffs[1], C: coeffs[2], D: coeffs[3] };
}

function planeFromIntegerCoefficients(A, B, C, D) {
    const len = Math.sqrt(A * A + B * B + C * C);
    if (len < 1e-9) return null;
    return {
        n: new Point3D(A / len, B / len, C / len),
        d: D / len
    };
}

function formatSignedTerm(value, variable, isFirst = false) {
    if (value === 0) return '';
    const sign = value < 0 ? '-' : (isFirst ? '' : '+');
    const abs = Math.abs(value);
    const coeff = abs === 1 ? '' : String(abs);
    return `${sign}${coeff}${variable}`;
}

function formatPlaneEquation(coeffs) {
    const terms = [];
    if (coeffs.A !== 0) terms.push(formatSignedTerm(coeffs.A, 'x', terms.length === 0));
    if (coeffs.B !== 0) terms.push(formatSignedTerm(coeffs.B, 'y', terms.length === 0));
    if (coeffs.C !== 0) terms.push(formatSignedTerm(coeffs.C, 'z', terms.length === 0));
    if (coeffs.D !== 0 || terms.length === 0) {
        const sign = coeffs.D < 0 ? '-' : (terms.length === 0 ? '' : '+');
        terms.push(`${sign}${Math.abs(coeffs.D)}`);
    }
    return `${terms.join(' ')} = 0`;
}

function polygonCenter(points) {
    if (!points || points.length === 0) return new Point3D(0, 0, 0);
    let c = new Point3D(0, 0, 0);
    for (const p of points) c = c.add(p);
    return c.scale(1 / points.length);
}

function lineFromTwoPlanes(plane1, plane2) {
    const n1 = plane1.n.normalize();
    const n2 = plane2.n.normalize();
    const dir = n1.cross(n2);
    if (dir.length() < 1e-8) return null;

    const absDir = { x: Math.abs(dir.x), y: Math.abs(dir.y), z: Math.abs(dir.z) };
    let p = null;

    if (absDir.x >= absDir.y && absDir.x >= absDir.z) {
        const det = n1.y * n2.z - n1.z * n2.y;
        if (Math.abs(det) < 1e-9) return null;
        const y = ((-plane1.d) * n2.z - n1.z * (-plane2.d)) / det;
        const z = (n1.y * (-plane2.d) - (-plane1.d) * n2.y) / det;
        p = new Point3D(0, y, z);
    } else if (absDir.y >= absDir.x && absDir.y >= absDir.z) {
        const det = n1.x * n2.z - n1.z * n2.x;
        if (Math.abs(det) < 1e-9) return null;
        const x = ((-plane1.d) * n2.z - n1.z * (-plane2.d)) / det;
        const z = (n1.x * (-plane2.d) - (-plane1.d) * n2.x) / det;
        p = new Point3D(x, 0, z);
    } else {
        const det = n1.x * n2.y - n1.y * n2.x;
        if (Math.abs(det) < 1e-9) return null;
        const x = ((-plane1.d) * n2.y - n1.y * (-plane2.d)) / det;
        const y = (n1.x * (-plane2.d) - (-plane1.d) * n2.x) / det;
        p = new Point3D(x, y, 0);
    }

    return { point: p, dir: dir.normalize() };
}

